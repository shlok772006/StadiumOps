# ── LLM Provider ──────────────────────────────────────────────────
# Options: gemini (default, free), anthropic, openai
LLM_PROVIDER=gemini

# ── Gemini (Google AI Studio — free, no credit card) ─────────────
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite

# ── Anthropic (requires billing) ─────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (requires billing) ────────────────────────────────────
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# ── Security & Rate Limiting Best Practices ──────────────────────
# 1. DO NOT commit actual API keys to VCS (Git). Always gitignore .env and .env.local.
# 2. Regularly rotate API keys to prevent unauthorized access.
# 3. Use restricted keys with appropriate permissions (read/write only on generation APIs).
# 4. In production environments, set up billing budgets, quota limits, and API request throttling (rate limiting) to mitigate DDoS/abuse.

